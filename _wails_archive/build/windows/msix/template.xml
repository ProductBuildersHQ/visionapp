<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="visionapp"
        Arguments=""
        InstallLocation="C:\Program Files\ProductBuildersHQ\VisionApp">
    </Installer>
    <PackageInformation
        PackageName="VisionApp"
        PackageDisplayName="VisionApp"
        PublisherName="CN=ProductBuildersHQ"
        PublisherDisplayName="ProductBuildersHQ"
        Version="0.1.0.0"
        PackageDescription="LLM-powered specification authoring and evaluation">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.productbuildershq.visionapp"
                Description="LLM-powered specification authoring and evaluation"
                DisplayName="VisionApp"
                ExecutableName="visionapp"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>VisionApp</DisplayName>
            <PublisherDisplayName>ProductBuildersHQ</PublisherDisplayName>
            <Description>LLM-powered specification authoring and evaluation</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="visionapp.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
