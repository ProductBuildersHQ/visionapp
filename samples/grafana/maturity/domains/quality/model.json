          "enablers": []
        },
        {
          "level": 3,
          "name": "Defined",
          "description": "Optimized CI",
          "criteria": [
            { "id": "ci-m3-dur", "name": "CI Duration", "sliId": "sli-ci-duration", "operator": "lte", "target": 30, "required": true },
