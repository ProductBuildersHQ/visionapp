      "unit": "minutes",
      "type": "quantitative",
      "sliType": "latency",
      "layer": "build",
      "category": "ci"
    },
    "sli-ci-success-rate": {
      "id": "sli-ci-success-rate",
      "name": "CI Success Rate",
      "description": "Percentage of CI runs that pass on first attempt",
      "metricName": "CI success rate",
      "unit": "percent",
      "type": "quantitative",
      "sliType": "reliability",
      "layer": "build",
      "category": "ci"
    },
    "sli-flaky-test-rate": {
      "id": "sli-flaky-test-rate",
      "name": "Flaky Test Rate",
      "description": "Percentage of tests flagged as flaky",
      "metricName": "Flaky test rate",
      "unit": "percent",
      "type": "quantitative",
      "sliType": "reliability",
      "layer": "build",
      "category": "testing"
    }
  },
