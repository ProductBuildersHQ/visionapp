          "criteria": [
            { "id": "ci-m5-dur", "name": "CI Duration", "sliId": "sli-ci-duration", "operator": "lte", "target": 15, "required": true },
            { "id": "ci-m5-rate", "name": "CI Success Rate", "sliId": "sli-ci-success-rate", "operator": "gte", "target": 98, "required": true },
            { "id": "ci-m5-flaky", "name": "Minimal Flaky Rate", "sliId": "sli-flaky-test-rate", "operator": "lte", "target": 1, "required": true }
