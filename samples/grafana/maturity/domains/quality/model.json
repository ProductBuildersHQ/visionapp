{
  "$schema": "https://github.com/grokify/prism/schema/prism-maturity-model.schema.json",
  "metadata": {
    "name": "Grafana Quality Engineering Maturity Model",
    "description": "Detailed maturity model for Grafana quality engineering",
    "version": "1.0.0",
    "organization": "Grafana Labs",
    "domain": "quality",
    "parentRef": "../../grafana.model.json",
    "createdAt": "2026-07-15",
    "updatedAt": "2026-07-15"
  },
  "slis": {
    "sli-go-coverage": {
      "id": "sli-go-coverage",
      "name": "Go Code Coverage",
      "description": "Unit test coverage for Go backend code",
      "metricName": "Go coverage percentage",
      "unit": "percent",
      "type": "quantitative",
      "sliType": "coverage",
      "layer": "build",
      "category": "testing"
    },
    "sli-react-coverage": {
      "id": "sli-react-coverage",
      "name": "React Code Coverage",
      "description": "Unit test coverage for React frontend code",
      "metricName": "React coverage percentage",
      "unit": "percent",
      "type": "quantitative",
      "sliType": "coverage",
      "layer": "build",
      "category": "testing"
    },
    "sli-e2e-coverage": {
      "id": "sli-e2e-coverage",
      "name": "E2E Test Coverage",
      "description": "End-to-end test coverage of critical user flows",
      "metricName": "E2E coverage percentage",
      "unit": "percent",
      "type": "quantitative",
      "sliType": "coverage",
      "layer": "build",
      "category": "testing"
    },
    "sli-e2e-reliability": {
      "id": "sli-e2e-reliability",
      "name": "E2E Test Reliability",
      "description": "E2E test pass rate excluding flakes",
      "metricName": "E2E reliability percentage",
      "unit": "percent",
      "type": "quantitative",
      "sliType": "reliability",
      "layer": "build",
      "category": "testing"
    },
    "sli-ci-duration": {
      "id": "sli-ci-duration",
      "name": "CI Pipeline Duration",
      "description": "Average CI pipeline completion time",
