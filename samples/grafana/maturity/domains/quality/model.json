            { "id": "e2e-m4-rel", "name": "E2E Reliability", "sliId": "sli-e2e-reliability", "operator": "gte", "target": 97, "required": true }
          ],
          "enablers": []
        },
        {
          "level": 5,
          "name": "Optimizing",
          "description": "Industry-leading E2E",
          "criteria": [
            { "id": "e2e-m5-cov", "name": "E2E Coverage", "sliId": "sli-e2e-coverage", "operator": "gte", "target": 95, "required": true },
