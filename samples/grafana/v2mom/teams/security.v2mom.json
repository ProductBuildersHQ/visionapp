      "status": "Mitigating"
    },
    {
      "id": "sec-obs-2",
      "name": "Plugin Security",
      "description": "Third-party plugins may introduce security vulnerabilities",
      "severity": "High",
      "likelihood": "Medium",
      "mitigation": "Plugin signing, sandbox environment, security review process",
      "status": "Mitigating"
    },
    {
      "id": "sec-obs-3",
