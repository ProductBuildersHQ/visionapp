      "description": "Security is built in from the start, not bolted on after",
      "priority": 1
    },
    {
      "name": "Transparency",
      "description": "Open about vulnerabilities, fixes, and security practices",
      "priority": 2
    },
    {
      "name": "Defense in Depth",
      "description": "Multiple layers of security controls, no single point of failure",
      "priority": 3
    },
    {
      "name": "Community Partnership",
      "description": "Work with security researchers through bug bounty and responsible disclosure",
      "priority": 4
    }
