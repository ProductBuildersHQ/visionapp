  "obstacles": [
    {
      "id": "core-obs-1",
      "name": "Legacy Code",
      "description": "Legacy AngularJS code limits performance and modern features",
      "severity": "High",
      "likelihood": "High",
      "mitigation": "Gradual migration to React, prioritize high-impact areas",
      "status": "Mitigating"
    },
    {
      "id": "core-obs-2",
      "name": "Browser Compatibility",
      "description": "Supporting older browsers limits use of modern web APIs",
      "severity": "Medium",
      "likelihood": "Medium",
      "mitigation": "Define clear browser support policy, use polyfills where needed",
      "status": "Accepted"
    }
  ],
