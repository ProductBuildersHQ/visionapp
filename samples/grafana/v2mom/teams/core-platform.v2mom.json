  "vision": "Build the most powerful, performant, and extensible observability visualization platform that delights millions of users daily.",
  "values": [
    {
      "name": "Performance First",
      "description": "Every feature must be fast; performance is a feature",
      "priority": 1
    },
    {
      "name": "Extensibility",
      "description": "Make it easy for anyone to extend Grafana through plugins",
      "priority": 2
    },
    {
      "name": "User Delight",
      "description": "Create intuitive, beautiful experiences that users love",
      "priority": 3
    },
    {
      "name": "Backward Compatibility",
      "description": "Don't break existing dashboards or workflows",
      "priority": 4
    }
  ],
  "methods": [
    {
      "id": "core-method-1",
      "name": "Dashboard Performance Excellence",
      "description": "Achieve sub-second dashboard load times for 99th percentile",
      "priority": "P0",
      "status": "In Progress",
      "owner": "Dashboard Team",
      "startDate": "2027-01-01",
      "endDate": "2027-06-30",
      "measures": [
        {
          "id": "perf-kr1",
          "name": "Dashboard Load P99",
          "baseline": "3.2s",
          "target": "< 1s",
          "current": "2.1s",
          "unit": "seconds",
          "progress": 0.5,
          "status": "On Track"
        },
        {
          "id": "perf-kr2",
          "name": "Query Execution P95",
          "baseline": "800ms",
          "target": "< 300ms",
          "current": "520ms",
          "unit": "milliseconds",
          "progress": 0.56,
          "status": "On Track"
        },
        {
          "id": "perf-kr3",
          "name": "Memory Usage",
          "baseline": "2.1GB",
          "target": "< 1.5GB",
          "current": "1.8GB",
          "unit": "GB",
          "progress": 0.5,
          "status": "On Track"
        }
      ],
      "projects": ["proj-query-cache", "proj-virtual-scrolling"]
    },
    {
