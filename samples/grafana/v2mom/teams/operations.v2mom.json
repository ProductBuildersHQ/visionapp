      "mitigation": "Improve SQLite HA, better database documentation",
      "status": "Mitigating"
    },
    {
      "id": "ops-obs-2",
      "name": "Legacy Alerting",
      "description": "Migration from legacy to unified alerting",
      "severity": "Medium",
      "likelihood": "High",
      "mitigation": "Migration tools, gradual deprecation",
      "status": "Mitigating"
    }
