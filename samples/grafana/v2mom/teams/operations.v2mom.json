  "vision": "Enable Grafana to run reliably at any scale, from single-node deployments to enterprise clusters handling millions of metrics.",
  "values": [
    {
      "name": "Reliability First",
      "description": "Grafana must be as reliable as the systems it monitors",
      "priority": 1
    },
    {
      "name": "Operational Simplicity",
      "description": "Make deployment and operations simple and predictable",
      "priority": 2
    },
    {
      "name": "Scale Gracefully",
      "description": "Performance should degrade gracefully under load",
      "priority": 3
    },
    {
      "name": "Observable Itself",
      "description": "Grafana should be easy to monitor and debug",
      "priority": 4
    }
  ],
  "methods": [
    {
      "id": "ops-method-1",
      "name": "Alerting Engine v2",
      "description": "Build next-generation alerting with better scalability and features",
      "priority": "P0",
      "status": "In Progress",
      "owner": "Alerting Team",
      "startDate": "2027-01-01",
      "endDate": "2027-12-31",
      "measures": [
        {
          "id": "alert-kr1",
          "name": "Alert Notification Channels",
          "baseline": "35",
          "target": "50",
          "current": "38",
          "unit": "channels",
          "progress": 0.2,
          "status": "On Track"
        },
        {
          "id": "alert-kr2",
          "name": "Alert Evaluation Latency P99",
          "baseline": "5s",
          "target": "< 1s",
          "current": "3s",
          "unit": "seconds",
          "progress": 0.5,
          "status": "On Track"
        },
        {
          "id": "alert-kr3",
          "name": "High-Cardinality Alert Support",
          "baseline": "10K series",
          "target": "1M series",
          "current": "50K series",
          "unit": "series",
          "progress": 0.04,
          "status": "At Risk"
        }
      ],
      "projects": ["proj-alerting-v2", "proj-alert-high-cardinality"]
    },
